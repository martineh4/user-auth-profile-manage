# Database - PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/auth_profile_db"

# NextAuth - generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Resend - https://resend.com (get a free API key at resend.com)
# If not set, email links are logged to the server console instead (dev only)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# RESEND_FROM="AuthProfile <noreply@yourdomain.com>"
